const container = document.getElementById('container');
let errorCount = 0;

function add_new_chars(n) {
    let str = '';
    for (let i = 0; i < n; i++) {
        str += String.fromCharCode(97 + Math.floor(Math.random() * 26));
    }
    return str;
}

window.onload = function() {
    container.textContent = add_new_chars(Math.floor(Math.random() * 3));
    container.focus();
};

window.addEventListener("keyup", function(e) {
    let currentText = container.textContent;
    
    if (currentText.length > 0 && e.key === currentText[0]) {
        container.textContent = currentText.substring(1);
        errorCount = 0;
    } else {
        errorCount++;
    }

    let charsToAdd = 3;
    if (errorCount >= 3) {
        charsToAdd += 3;
        errorCount = 0;
    }

    container.textContent += add_new_chars(charsToAdd);
});
